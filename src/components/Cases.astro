---
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/${n}`;
const cases = [
  {
    img: 'case-prototype.png',
    tag: 'PROTOTYPE · 파주',
    title: 'DMZ 탈출 시뮬레이션',
    sub: '체력·선택지·실패조건 게임. 학생 2명이 4시간 만에 제작.',
    ribbon: 'NEW · 2025',
  },
  {
    img: 'case-simulation.png',
    tag: 'SIMULATION · 도시',
    title: '도시 정책 시뮬레이션',
    sub: '규칙과 변수를 갖춘 작은 살아있는 월드.',
  },
  {
    img: 'case-twin.png',
    tag: 'DIGITAL TWIN · 산업',
    title: '디지털 트윈 입문',
    sub: '현실의 공간·자원·규칙을 디지털 환경에 옮기기.',
  },
  {
    img: 'case-village.png',
    tag: 'AGENT · 순순빌리지',
    title: 'AI 에이전트 마을',
    sub: '캐릭터마다 페르소나를 가진 가상 마을.',
  },
];
---
<section id="cases">
  <div class="container">
    <div class="sec-head">
      <span class="sec-num">/ 04 — CASES</span>
      <h2 class="sec-title">학생의 질문이<br><span class="grad">작은 연구실</span>이 됩니다.</h2>
      <p class="sec-desc">
        급식 동선부터 도시 정책까지 — 학생의 관심 주제는 게임·시뮬레이션·디지털 트윈의 출발점.
        2025 파주고등 진로캠프에서 실제로 만들어진 작품을 포함합니다.
      </p>
    </div>

    <div class="cases-grid">
      {cases.map(c => (
        <article class="case">
          {c.ribbon && <span class="ribbon">{c.ribbon}</span>}
          <div class="img"><img src={img(c.img)} alt={c.title} loading="lazy"/></div>
          <div class="body">
            <div class="tag">{c.tag}</div>
            <h4>{c.title}</h4>
            <div class="sub">{c.sub}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cases-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .case {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform .25s, box-shadow .25s, border-color .25s;
    cursor: pointer;
    position: relative;
  }
  .case:hover { transform: translateY(-4px); border-color: var(--violet-300); box-shadow: var(--shadow-md); }
  .img { aspect-ratio: 4/3; background: var(--bg-2); }
  .img img { width: 100%; height: 100%; object-fit: cover; }
  .body { padding: 16px 18px 20px; }
  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.14em;
    color: var(--violet-600);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  h4 { font-weight: 700; font-size: 17px; letter-spacing: -0.015em; margin-bottom: 4px; }
  .sub { font-size: 13px; color: var(--ink-3); line-height: 1.5; }
  .ribbon {
    position: absolute; top: 12px; left: 12px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
    background: var(--amber-400);
    color: #5a3500;
    padding: 4px 8px;
    border-radius: 6px;
    box-shadow: 0 4px 12px rgba(255,167,60,0.4);
    z-index: 2;
  }
  @media (max-width: 980px) {
    .cases-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
