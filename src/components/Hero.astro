---
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/${n}`;
---
<header class="hero" id="top">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">AI · PBL · GAME · SIMULATION</span>
      <h1>
        AI로 <span class="grad">장난감</span>처럼<br>
        만들고, <span class="underline">실험</span>하고,<br>
        나만의 <span class="grad">연구실</span>이 된다.
      </h1>
      <p class="lede">
        <b>GenJ</b>는 학생이 자신의 질문을 게임처럼 만들고 시뮬레이션처럼 시험하며,
        나만의 작은 연구실로 발전시키는 <b>PBL 기반 AI 창작 교육</b>입니다.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#program">
          프로그램 살펴보기
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8m0 0L7 3m4 4l-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </a>
        <a class="btn btn-ghost" href="#cases">학생 작품 보기</a>
      </div>

      <div class="hero-pills">
        <span class="pill"><i></i>AI 활용 교육</span>
        <span class="pill"><i></i>게임 프로토타이핑</span>
        <span class="pill"><i></i>시뮬레이션 학습</span>
        <span class="pill"><i></i>디지털 트윈 입문</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="image-frame">
        <img src={img('hero-scene.png')} alt="GenJ AI Creative Playground" loading="eager" />
      </div>
      <div class="badge b1">
        <div class="ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
        </div>
        <div>
          <strong>3F 개발법</strong>
          <span>Fast Thinking · Making · Feedback</span>
        </div>
      </div>
      <div class="badge b2">
        <div class="ico" style="background: linear-gradient(135deg, #FFE4C2, #FFC470);">
          <svg viewBox="0 0 24 24" fill="none" stroke="#B85000" stroke-width="2"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div>
          <strong>2025 파주 진로캠프</strong>
          <span>2026년 3회 진행 예정</span>
        </div>
      </div>
      <div class="badge b3">
        <div class="ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </div>
        <div>
          <strong>SAM · SPUM BASE</strong>
          <span>자체 AI 인프라</span>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .hero { padding: 80px 0 64px; }
  .hero-grid {
    display: grid; grid-template-columns: 1fr 1.05fr; gap: 48px; align-items: center;
  }
  .eyebrow { margin-bottom: 24px; }

  h1 {
    font-weight: 800;
    font-size: clamp(40px, 6.4vw, 84px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin-bottom: 22px;
  }
  h1 .grad {
    background: var(--grad-brand);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  h1 .underline { position: relative; display: inline-block; }
  h1 .underline::after {
    content: ''; position: absolute;
    left: -2%; right: -2%; bottom: 4%; height: 14%;
    background: linear-gradient(180deg, transparent 60%, var(--amber-300) 60%);
    z-index: -1; border-radius: 4px; opacity: .7;
  }
  .lede {
    font-size: 18px; color: var(--ink-2);
    line-height: 1.6; max-width: 38ch; margin-bottom: 32px;
  }
  .lede :global(b) { color: var(--ink); font-weight: 600; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-pills { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 32px; }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 12px; color: var(--ink-2); font-weight: 500;
  }
  .pill i {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--violet-500);
  }

  .hero-visual { position: relative; border-radius: 28px; }
  .image-frame {
    border-radius: 28px;
    overflow: hidden;
    background: var(--card);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--line);
    aspect-ratio: 3/2;
  }
  .image-frame img { width: 100%; height: 100%; object-fit: cover; }

  .badge {
    position: absolute;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 12px 14px;
    box-shadow: var(--shadow-md);
    display: flex; align-items: center; gap: 10px;
    font-size: 13px;
  }
  .badge .ico {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--grad-soft);
    border: 1px solid var(--violet-100);
    display: grid; place-items: center;
  }
  .badge .ico svg { width: 18px; height: 18px; color: var(--violet-600); }
  .badge strong { display: block; font-weight: 600; color: var(--ink); }
  .badge span { color: var(--ink-3); font-size: 11px; }
  .b1 { top: -16px; left: -16px; animation: floaty 4.5s ease-in-out infinite; }
  .b2 { bottom: -16px; right: -8px; animation: floaty 5s ease-in-out infinite reverse; }
  .b3 { top: 35%; right: -32px; animation: floaty 4s ease-in-out infinite; }

  @media (max-width: 980px) {
    .hero-grid { grid-template-columns: 1fr; }
    .b3 { display: none; }
  }
</style>
