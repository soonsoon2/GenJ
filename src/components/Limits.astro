---
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/${n}`;
const items = [
  { t: '사용 제한',         d: '학생 수·세션·사용량 한도로 안정적 수업 운영이 어려움' },
  { t: '커스텀 한계',       d: '기관·지역·수업별 전용 환경을 구성하기 어려움' },
  { t: '연령대 제어 부족',  d: '10대 학생에 맞춘 콘텐츠·표현·난이도 조절이 어려움' },
  { t: '모니터링 부족',     d: '교사·매니저가 학생 진행 상황을 확인하기 어려움' },
  { t: '데이터 관리 한계',  d: '프롬프트·히스토리·결과물·피드백을 축적·분석하기 어려움' },
  { t: '비용·정책 리스크',  d: '외부 서비스 요금·정책·접속 환경 변화에 영향' },
];
---
<section id="limits">
  <div class="container">
    <div class="grid">
      <div class="visual">
        <img src={img('limits-diagram.png')} alt="" loading="lazy" />
      </div>
      <div>
        <span class="sec-num">/ 03.5 — WHY OWN PLATFORM</span>
        <h2 class="sec-title" style="margin-top: 14px">외산 AI 도구만으로는<br><span class="grad">학교·공공 교육</span>이 어렵습니다.</h2>
        <p class="sec-desc" style="margin: 14px 0 28px">
          2025년 실제 고등학생 대상 AI 게임 제작 교육을 운영하면서, Gemini Canvas 등 외산 AI 서비스 기반 수업에서 다음과 같은 한계를 확인했습니다.
        </p>

        <div class="list">
          {items.map((it, i) => (
            <div class="row">
              <div class="num">0{i + 1}</div>
              <div>
                <div class="t">{it.t}</div>
                <div class="d">{it.d}</div>
              </div>
            </div>
          ))}
        </div>

        <p class="callout">
          학교 교사·기관 매니저가 통제·모니터링·데이터 관리를 할 수 있는 <b>자체 교육 플랫폼</b>이 필요합니다.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 48px; align-items: center; }
  .visual {
    border-radius: 22px; overflow: hidden;
    border: 1px solid var(--line);
    background: var(--card);
    box-shadow: var(--shadow-md);
    aspect-ratio: 1/1;
  }
  .visual img { width: 100%; height: 100%; object-fit: cover; }

  .list { display: grid; gap: 10px; margin-bottom: 24px; }
  .row {
    display: grid; grid-template-columns: 36px 1fr; gap: 12px;
    padding: 14px 16px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    align-items: start;
  }
  .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 600;
    color: var(--violet-600);
    background: var(--violet-50);
    padding: 4px 0;
    text-align: center;
    border-radius: 8px;
  }
  .t { font-weight: 600; color: var(--ink); margin-bottom: 2px; }
  .d { font-size: 13px; color: var(--ink-3); line-height: 1.5; }

  .callout {
    padding: 18px 20px;
    background: var(--grad-soft);
    border: 1px solid var(--violet-100);
    border-radius: 14px;
    color: var(--ink);
    font-size: 15px; line-height: 1.6;
    font-weight: 500;
  }
  .callout :global(b) {
    background: var(--grad-brand);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
