---
const base = import.meta.env.BASE_URL;
const pdfHref = `${base.replace(/\/$/, '')}/GenJ_Proposal.pdf`;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/slides/${n}`;
---
<section id="showcase">
  <div class="container">
    <div class="sec-head">
      <span class="sec-num">/ 08 — PROPOSAL</span>
      <h2 class="sec-title">제안서 <span class="grad">다운로드</span>.</h2>
      <p class="sec-desc">
        GenJ 교육법과 플랫폼 개발 파트너 유치 제안서 전문입니다.
      </p>
    </div>

    <div class="download-card">
      <div class="preview">
        <img src={img('full-page01.jpg')} alt="GenJ 제안서 표지" loading="lazy" />
        <div class="overlay">
          <span class="pages">10 pages · PDF · 2.2MB</span>
        </div>
      </div>
      <div class="info">
        <h3>GenJ 소개서</h3>
        <p>교육 철학 · 3F 개발법 · 플랫폼 구성 · 적용 시나리오 · 교육 실증 · 파트너십 제안 · 기술 기반 · 대표자 역량</p>
        <a class="dl-btn" href={pdfHref} download="GenJ_Proposal.pdf">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          제안서 다운로드 (PDF)
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .download-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 24px;
    box-shadow: var(--shadow-md);
  }
  .preview {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16/9;
    background: #0E0B1E;
  }
  .preview img { width: 100%; height: 100%; object-fit: contain; }
  .overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 12px 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
  }
  .pages {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.05em;
  }
  .info { padding: 8px 16px; }
  .info h3 {
    font-weight: 700;
    font-size: 28px;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }
  .info p {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: var(--grad-brand);
    color: #fff;
    border-radius: 12px;
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(124,58,237,0.32);
    transition: transform .2s, box-shadow .2s;
  }
  .dl-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(124,58,237,0.42);
  }

  @media (max-width: 768px) {
    .download-card { grid-template-columns: 1fr; }
  }
</style>
