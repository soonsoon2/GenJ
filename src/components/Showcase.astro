---
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/slides/${n}`;
const slides = [
  { src: 'full-page01.jpg', label: '표지 · GenJ 소개' },
  { src: 'full-page02.jpg', label: '교육 철학' },
  { src: 'full-page03.jpg', label: '3F 개발법' },
  { src: 'full-page04.jpg', label: 'AI 페이퍼 프로토타입' },
  { src: 'full-page05.jpg', label: '플랫폼 구성' },
  { src: 'full-page06.jpg', label: '적용 시나리오' },
  { src: 'full-page07.jpg', label: '교육 실증' },
  { src: 'full-page08.jpg', label: '파트너십 제안' },
  { src: 'full-page09.jpg', label: '기술 기반' },
  { src: 'full-page10.jpg', label: '대표자 역량' },
];
---
<section id="showcase">
  <div class="container">
    <div class="sec-head">
      <span class="sec-num">/ 08 — PROPOSAL DECK</span>
      <h2 class="sec-title">제안서 <span class="grad">미리보기</span>.</h2>
      <p class="sec-desc">
        GenJ 교육법과 플랫폼 개발 파트너 유치 제안서의 핵심 슬라이드입니다.
        전체 제안서는 별도 요청 시 공유드립니다.
      </p>
    </div>

    <div class="carousel">
      <div class="track" id="slideTrack">
        {slides.map((s, i) => (
          <div class="slide">
            <div class="frame">
              <img src={img(s.src)} alt={s.label} loading="lazy" />
            </div>
            <div class="caption">
              <span class="num">{String(i + 1).padStart(2, '0')}</span>
              <span class="label">{s.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="controls">
      <button class="arrow left" id="prevSlide" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="dots" id="slideDots">
        {slides.map((_, i) => (
          <button class={`dot ${i === 0 ? 'active' : ''}`} data-idx={i} aria-label={`Slide ${i + 1}`}></button>
        ))}
      </div>
      <button class="arrow right" id="nextSlide" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  #showcase { padding-bottom: 48px; }
  .carousel {
    position: relative;
    overflow: hidden;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--bg-2);
    box-shadow: var(--shadow-md);
  }
  .track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .slide {
    min-width: 100%;
    flex-shrink: 0;
  }
  .frame {
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .frame img {
    width: 100%; height: 100%; object-fit: contain;
    background: #0E0B1E;
  }
  .caption {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 20px;
    background: var(--card);
    border-top: 1px solid var(--line);
  }
  .caption .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--violet-600);
    background: var(--violet-50);
    padding: 3px 8px; border-radius: 6px;
    font-weight: 500;
  }
  .caption .label { font-size: 14px; color: var(--ink-2); font-weight: 500; }

  .controls {
    display: flex; align-items: center; justify-content: center;
    gap: 16px;
    margin-top: 20px;
  }
  .arrow {
    width: 40px; height: 40px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: var(--card);
    display: grid; place-items: center;
    cursor: pointer;
    color: var(--ink);
    transition: all .2s;
    box-shadow: var(--shadow-sm);
  }
  .arrow:hover { border-color: var(--violet-300); color: var(--violet-600); }
  .dots { display: flex; gap: 6px; }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--line);
    cursor: pointer;
    transition: all .2s;
  }
  .dot.active { background: var(--violet-600); transform: scale(1.3); }
</style>

<script>
  const track = document.getElementById('slideTrack') as HTMLElement;
  const dots = document.querySelectorAll('#slideDots .dot');
  const prev = document.getElementById('prevSlide');
  const next = document.getElementById('nextSlide');
  const total = dots.length;
  let current = 0;

  function goTo(idx: number) {
    current = ((idx % total) + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  prev?.addEventListener('click', () => goTo(current - 1));
  next?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

  // Auto-advance every 6s
  let timer = setInterval(() => goTo(current + 1), 6000);
  track.parentElement?.addEventListener('mouseenter', () => clearInterval(timer));
  track.parentElement?.addEventListener('mouseleave', () => {
    timer = setInterval(() => goTo(current + 1), 6000);
  });
</script>
