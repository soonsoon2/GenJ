---
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/${n}`;

const steps = [
  {
    n: 'F.01',
    title: '빠르게 생각',
    en: 'FAST · THINKING',
    desc: 'AI와 대화하며 아이디어를 꺼내고, 막연한 질문을 목표·규칙·조건으로 구조화합니다.',
    img: '3f-thinking.png',
  },
  {
    n: 'F.02',
    title: '빠르게 만들기',
    en: 'FAST · MAKING',
    desc: '완성도보다 작동. 웹 미니게임·텍스트 게임·시뮬레이션으로 즉시 구현합니다.',
    img: '3f-making.png',
  },
  {
    n: 'F.03',
    title: '빠르게 피드백',
    en: 'FAST · FEEDBACK',
    desc: '친구·교사·AI 에이전트의 피드백을 받아 다시 개선하고, 그 과정을 기록합니다.',
    img: '3f-feedback.png',
  },
];
---
<section id="method">
  <div class="container">
    <div class="sec-head">
      <span class="sec-num">/ 02 — METHOD</span>
      <h2 class="sec-title">완성보다 <span class="grad">반복</span>.<br>3F 개발법.</h2>
      <p class="sec-desc">
        AI와 함께 빠르게 생각하고, 만들고, 피드백을 받는 3단계 루프.
        완벽한 기획서가 아니라 작동하는 프로토타입에서 시작합니다.
      </p>
    </div>

    <div class="threef">
      {steps.map(s => (
        <article class="f-card">
          <div class="thumb">
            <img src={img(s.img)} alt={s.title} loading="lazy" />
          </div>
          <div class="meta">
            <span class="num-pill">{s.n}</span>
            <div class="en">{s.en}</div>
          </div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .threef { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .f-card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 24px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: transform .25s, box-shadow .25s, border-color .25s;
  }
  .f-card:hover {
    transform: translateY(-4px);
    border-color: var(--violet-300);
    box-shadow: var(--shadow-md);
  }
  .thumb {
    aspect-ratio: 5/3;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 20px;
    background: var(--bg-2);
    border: 1px solid var(--line);
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .meta {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 8px;
  }
  .num-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; padding: 3px 10px;
    background: var(--violet-50);
    color: var(--violet-700);
    border-radius: 999px;
    font-weight: 500;
  }
  .en {
    font-family: 'Space Grotesk', monospace;
    font-size: 11px; letter-spacing: 0.16em;
    color: var(--ink-3); text-transform: uppercase;
  }
  h3 { font-weight: 700; font-size: 22px; letter-spacing: -0.02em; margin-bottom: 8px; }
  p { font-size: 14px; color: var(--ink-2); line-height: 1.6; }

  @media (max-width: 980px) { .threef { grid-template-columns: 1fr; } }
</style>
