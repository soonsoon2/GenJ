---
const base = import.meta.env.BASE_URL;
const img = (n: string) => `${base.replace(/\/$/, '')}/images/${n}`;

const items = [
  {
    title: 'AI 활용 교육',
    en: 'AI LITERACY',
    desc: '프롬프트 설계, 결과 검증, 오류 수정. 멀티 AI 활용까지.',
    img: 'program-ai.png',
  },
  {
    title: '게임 개발 교육',
    en: 'GAME DESIGN',
    desc: '목표·규칙·난이도·피드백·캐릭터·세계관을 직접 설계.',
    img: 'program-game.png',
  },
  {
    title: '시뮬레이션 학습',
    en: 'SIMULATION',
    desc: '역할·조건·사건의 결과를 디지털 환경에서 실험.',
    img: 'program-sim.png',
  },
  {
    title: '디지털 트윈 입문',
    en: 'DIGITAL TWIN',
    desc: '학교·지역·산업 공간을 디지털 환경으로 재구성.',
    img: 'program-twin.png',
  },
];
---
<section id="program">
  <div class="container">
    <div class="sec-head">
      <span class="sec-num">/ 01 — PROGRAM</span>
      <h2 class="sec-title">게임 개발에서 시작해<br><span class="grad">디지털 트윈</span>까지.</h2>
      <p class="sec-desc">
        GenJ는 단일 수업이 아닌 4개 영역으로 확장되는 AI 창작 교육 프레임입니다.
        학생의 관심·전공·지역에 따라 깊이를 조절합니다.
      </p>
    </div>
    <div class="grid">
      {items.map((it, i) => (
        <article class="item">
          <div class="thumb">
            <img src={img(it.img)} alt={it.title} loading="lazy" />
          </div>
          <div class="num">0{i + 1}</div>
          <h3>{it.title}</h3>
          <div class="en">{it.en}</div>
          <p>{it.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .item {
    position: relative;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 20px;
    box-shadow: var(--shadow-sm);
    transition: transform .25s, border-color .25s, box-shadow .25s;
    overflow: hidden;
  }
  .item:hover {
    transform: translateY(-4px);
    border-color: var(--violet-300);
    box-shadow: var(--shadow-md);
  }
  .thumb {
    aspect-ratio: 1/1;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 18px;
    background: var(--bg-2);
    border: 1px solid var(--line);
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .num {
    position: absolute; top: 32px; right: 32px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--violet-700);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(4px);
    padding: 3px 8px; border-radius: 999px;
    font-weight: 500;
    border: 1px solid var(--line);
  }
  h3 { font-weight: 700; font-size: 19px; letter-spacing: -0.02em; margin-bottom: 4px; padding: 0 4px; }
  .en {
    font-family: 'Space Grotesk', monospace;
    font-size: 11px; letter-spacing: 0.16em;
    color: var(--ink-3); text-transform: uppercase;
    margin-bottom: 12px;
    padding: 0 4px;
  }
  p { font-size: 14px; color: var(--ink-2); line-height: 1.55; padding: 0 4px; }

  @media (max-width: 980px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
