---
interface Props { size?: number; idSuffix?: string; }
const { size = 36, idSuffix = '' } = Astro.props;
const gid = `genj-logo-grad-${idSuffix}`;
---
<svg viewBox="0 0 64 64" fill="none" width={size} height={size} aria-hidden="true">
  <defs>
    <linearGradient id={gid} x1="0" y1="0" x2="64" y2="64">
      <stop offset="0%" stop-color="#7C3AED"/>
      <stop offset="50%" stop-color="#6366F1"/>
      <stop offset="100%" stop-color="#22D3EE"/>
    </linearGradient>
  </defs>
  <path d="M32 4 L56 18 L56 46 L32 60 L8 46 L8 18 Z" fill={`url(#${gid})`}/>
  <path d="M32 18 a14 14 0 1 0 14 14 H34" stroke="#fff" stroke-width="3.6" stroke-linecap="round" fill="none"/>
  <path d="M44 22 l1.2 3.2 l3.2 1.2 l-3.2 1.2 l-1.2 3.2 l-1.2 -3.2 l-3.2 -1.2 l3.2 -1.2 z" fill="#fff"/>
  <rect x="14" y="10" width="3" height="3" fill="#22D3EE"/>
  <rect x="20" y="6"  width="2" height="2" fill="#67E8F9"/>
</svg>
